# SurfMyCycle 环境变量配置
# 复制此文件为 .env.local 并填入真实值，或直接在 Vercel Dashboard 中配置

# ==========================================
# Supabase 配置 (必需)
# 从 https://supabase.com/dashboard → 你的项目 → Project Settings → API 获取
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ==========================================
# MiniMax API (必需)
# 从 https://www.minimaxi.com/platform → API Keys 获取
# ==========================================
MINIMAX_API_KEY=your-minimax-api-key

# ==========================================
# 可选配置
# ==========================================
# AUTH_SECRET=your-auth-secret-for-jwt
